<h1>Transmutacoes</h1>

<div>
  <%= link_to "Nova Transmutacao", new_transmutacao_path %>
</div>

<h2>Basicas</h2>
<div style="display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px;">
  <% @transmutacaos_basicas.each do |transmutacao| %>
    <div style="width: 180px; border: 1px solid #ccc; border-radius: 8px; padding: 8px; text-align: center;">
      <% if transmutacao.imagem.present? %>
        <%= image_tag transmutacao.imagem.gsub('app/assets/images/', ''), style: "width: 100%; border-radius: 4px;" %>
      <% end %>
      <p><strong><%= transmutacao.nome %></strong></p>
      <p>Custo: x<%= transmutacao.custo_multiplicador %> | Dado: <%= transmutacao.dado_poder %></p>
      <div>
        <%= link_to "Ver", transmutacao %>
        <%= link_to "Editar", edit_transmutacao_path(transmutacao) %>
        <%= link_to "Deletar", transmutacao, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  <% end %>
</div>

<h2>Disciplinas</h2>
<div style="display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px;">
  <% @transmutacaos_disciplina.each do |transmutacao| %>
    <div style="width: 180px; border: 1px solid #ccc; border-radius: 8px; padding: 8px; text-align: center;">
      <% if transmutacao.imagem.present? %>
        <%= image_tag transmutacao.imagem.gsub('app/assets/images/', ''), style: "width: 100%; border-radius: 4px;" %>
      <% end %>
      <p><strong><%= transmutacao.nome %></strong></p>
      <p><%= transmutacao.disciplina_nome %> (Nv <%= transmutacao.nivel_minimo %>)</p>
      <p>Custo: x<%= transmutacao.custo_multiplicador %> | Dado: <%= transmutacao.dado_poder %></p>
      <div>
        <%= link_to "Ver", transmutacao %>
        <%= link_to "Editar", edit_transmutacao_path(transmutacao) %>
        <%= link_to "Deletar", transmutacao, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  <% end %>
</div>