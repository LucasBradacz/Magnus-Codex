<h1>Modificadores</h1>

<h2>Básicos</h2>
<table>
  <thead>
  <tr>
    <th>Nome</th>
    <th>Operação de Custo</th>
    <th>Valor do Custo</th>
    <th>Ações</th>
  </tr>
  </thead>
  <tbody>
  <% @modificadors_basicos.each do |modificador| %>
    <tr>
      <td><%= modificador.nome %></td>
      <td><%= modificador.operacao_custo %></td>
      <td><%= modificador.valor_custo %></td>
      <td>
        <%= link_to "Ver", modificador %>
        <%= link_to "Editar", edit_modificador_path(modificador) %>
        <%= link_to "Apagar", modificador, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>

<h2>Disciplinas</h2>
<table>
  <thead>
  <tr>
    <th>Nome</th>
    <th>Disciplina</th>
    <th>Nível Mínimo</th>
    <th>Operação de Custo</th>
    <th>Valor do Custo</th>
    <th>Ações</th>
  </tr>
  </thead>
  <tbody>
  <% @modificadors_disciplina.each do |modificador| %>
    <tr>
      <td><%= modificador.nome %></td>
      <td><%= modificador.disciplina_nome %></td>
      <td><%= modificador.nivel_minimo %></td>
      <td><%= modificador.operacao_custo %></td>
      <td><%= modificador.valor_custo %></td>
      <td>
        <%= link_to "Ver", modificador %>
        <%= link_to "Editar", edit_modificador_path(modificador) %>
        <%= link_to "Apagar", modificador, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>

<%= link_to "Novo Modificador", new_modificador_path %>
