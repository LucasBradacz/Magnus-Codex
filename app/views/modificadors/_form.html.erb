<%= form_with(model: modificador) do |form| %>
  <% if modificador.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(modificador.errors.count, "erro") %> encontrados:</h2>
      <ul>
        <% modificador.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :nome, "Nome:" %>
    <%= form.text_field :nome %>
  </div>

  <div>
    <%= form.label :descricao, "Descrição:" %>
    <%= form.text_area :descricao %>
  </div>

  <div>
    <%= form.label :operacao_custo, "Operação de Custo:" %>
    <%= form.select :operacao_custo, [["Soma", "soma"], ["Multiplicação", "multiplicacao"], ["Divisão", "divisao"], ["Subtração", "subtracao"]] %>
  </div>

  <div>
    <%= form.label :valor_custo, "Valor do Custo:" %>
    <%= form.number_field :valor_custo, step: 0.1 %>
  </div>

  <div>
    <%= form.label :operacao_poder, "Operação de Poder:" %>
    <%= form.select :operacao_poder, [["Nenhuma", ""], ["Soma", "soma"], ["Multiplicação", "multiplicacao"], ["Divisão", "divisao"], ["Subtração", "subtracao"]], include_blank: true %>
  </div>

  <div>
    <%= form.label :valor_poder, "Valor do Poder:" %>
    <%= form.number_field :valor_poder, step: 0.1 %>
  </div>

  <div>
    <%= form.label :efeito, "Efeito:" %>
    <%= form.text_area :efeito %>
  </div>

  <div>
    <%= form.label :basica, "Carta Básica?" %>
    <%= form.check_box :basica %>
  </div>

  <div>
    <%= form.label :disciplina, "Disciplina:" %>
    <%= form.select :disciplina, [
      ["Nenhuma (Básica)", ""],
      ["Superior (Vida/Cura)", "superior"],
      ["Esquerda Superior (Mente)", "esquerda_superior"],
      ["Direita Superior (Melhoria)", "direita_superior"],
      ["Esquerda Inferior (Contenção)", "esquerda_inferior"],
      ["Direita Inferior (Destruição)", "direita_inferior"]
    ], include_blank: false %>
  </div>

  <div>
    <%= form.label :nivel_minimo, "Nível Mínimo na Disciplina:" %>
    <%= form.number_field :nivel_minimo %>
  </div>

  <div>
    <%= form.submit "Salvar" %>
  </div>
<% end %>
