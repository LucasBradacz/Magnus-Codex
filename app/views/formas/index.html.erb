<h1>Formas</h1>

<div>
  <%= link_to "Nova Forma", new_forma_path %>
</div>

<h2>Basicas</h2>
<div style="display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px;">
  <% @formas_basicas.each do |forma| %>
    <div style="width: 180px; border: 1px solid #ccc; border-radius: 8px; padding: 8px; text-align: center;">
      <% if forma.imagem.present? %>
        <%= image_tag forma.imagem.gsub('app/assets/images/', ''), style: "width: 100%; border-radius: 4px;" %>
      <% end %>
      <p><strong><%= forma.nome %></strong></p>
      <p>Custo: <%= forma.custo_base %> | Poder: <%= forma.poder_base %></p>
      <div>
        <%= link_to "Ver", forma %>
        <%= link_to "Editar", edit_forma_path(forma) %>
        <%= link_to "Deletar", forma, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  <% end %>
</div>

<h2>Disciplinas</h2>
<div style="display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px;">
  <% @formas_disciplina.each do |forma| %>
    <div style="width: 180px; border: 1px solid #ccc; border-radius: 8px; padding: 8px; text-align: center;">
      <% if forma.imagem.present? %>
        <%= image_tag forma.imagem.gsub('app/assets/images/', ''), style: "width: 100%; border-radius: 4px;" %>
      <% end %>
      <p><strong><%= forma.nome %></strong></p>
      <p><%= forma.disciplina_nome %> (Nv <%= forma.nivel_minimo %>)</p>
      <p>Custo: <%= forma.custo_base %> | Poder: <%= forma.poder_base %></p>
      <div>
        <%= link_to "Ver", forma %>
        <%= link_to "Editar", edit_forma_path(forma) %>
        <%= link_to "Deletar", forma, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  <% end %>
</div>