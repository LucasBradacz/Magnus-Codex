<%= form_with(model: personagem) do |form| %>
  <% if personagem.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(personagem.errors.count, "erro") %> encontrados:</h2>
      <ul>
        <% personagem.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :nome, "Nome:" %>
    <%= form.text_field :nome %>
  </div>

  <div>
    <%= form.label :player, "Player:" %>
    <%= form.text_field :player %>
  </div>

  <div>
    <%= form.label :nivel, "Nível:" %>
    <%= form.number_field :nivel %>
  </div>

  <h3>Atributos</h3>
  <p>Distribua os valores 4, 3, 2, 2, 1 nos atributos abaixo:</p>

  <div>
    <%= form.label :agilidade, "Agilidade:" %>
    <%= form.number_field :agilidade %>
  </div>

  <div>
    <%= form.label :dominio, "Domínio:" %>
    <%= form.number_field :dominio %>
  </div>

  <div>
    <%= form.label :percepcao, "Percepção:" %>
    <%= form.number_field :percepcao %>
  </div>

  <div>
    <%= form.label :potencia, "Potência:" %>
    <%= form.number_field :potencia %>
  </div>

  <div>
    <%= form.label :resistencia, "Resistência:" %>
    <%= form.number_field :resistencia %>
  </div>

  <h3>Status Atual</h3>
  <p>Os valores máximos são calculados automaticamente.</p>

  <div>
    <%= form.label :vida_atual, "Vida Atual:" %>
    <%= form.number_field :vida_atual %>
  </div>

  <div>
    <%= form.label :mana_atual, "Mana Atual:" %>
    <%= form.number_field :mana_atual %>
  </div>

  <div>
    <%= form.label :estabilidade_atual, "Estabilidade Atual:" %>
    <%= form.number_field :estabilidade_atual %>
  </div>

  <div>
    <%= form.label :dinheiro, "Dinheiro:" %>
    <%= form.number_field :dinheiro, step: 0.01 %>
  </div>

  <h3>Pentagrama</h3>

  <div>
    <%= form.label :nivel_superior, "Superior (Vida/Cura):" %>
    <%= form.number_field :nivel_superior %>
  </div>

  <div>
    <%= form.label :nivel_esquerda_superior, "Esquerda Superior (Mente):" %>
    <%= form.number_field :nivel_esquerda_superior %>
  </div>

  <div>
    <%= form.label :nivel_direita_superior, "Direita Superior (Melhoria):" %>
    <%= form.number_field :nivel_direita_superior %>
  </div>

  <div>
    <%= form.label :nivel_esquerda_inferior, "Esquerda Inferior (Contenção):" %>
    <%= form.number_field :nivel_esquerda_inferior %>
  </div>

  <div>
    <%= form.label :nivel_direita_inferior, "Direita Inferior (Destruição):" %>
    <%= form.number_field :nivel_direita_inferior %>
  </div>

  <div>
    <%= form.submit "Salvar" %>
  </div>
<% end %>
