<%= form_with(model: modificador) do |form| %>
  <% if modificador.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(modificador.errors.count, "error") %> prohibited this modificador from being saved:</h2>

      <ul>
        <% modificador.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
