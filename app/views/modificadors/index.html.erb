<h1>Modificadores</h1>

<div>
  <%= link_to "Novo Modificador", new_modificador_path %>
</div>

<h2>Basicos</h2>
<div style="display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px;">
  <% @modificadors_basicos.each do |modificador| %>
    <div style="width: 180px; border: 1px solid #ccc; border-radius: 8px; padding: 8px; text-align: center;">
      <% if modificador.imagem.present? %>
        <%= image_tag modificador.imagem.gsub('app/assets/images/', ''), style: "width: 100%; border-radius: 4px;" %>
      <% end %>
      <p><strong><%= modificador.nome %></strong></p>
      <p>Custo: <%= modificador.operacao_custo %> <%= modificador.valor_custo %></p>
      <div>
        <%= link_to "Ver", modificador %>
        <%= link_to "Editar", edit_modificador_path(modificador) %>
        <%= link_to "Deletar", modificador, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  <% end %>
</div>

<h2>Disciplinas</h2>
<div style="display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px;">
  <% @modificadors_disciplina.each do |modificador| %>
    <div style="width: 180px; border: 1px solid #ccc; border-radius: 8px; padding: 8px; text-align: center;">
      <% if modificador.imagem.present? %>
        <%= image_tag modificador.imagem.gsub('app/assets/images/', ''), style: "width: 100%; border-radius: 4px;" %>
      <% end %>
      <p><strong><%= modificador.nome %></strong></p>
      <p><%= modificador.disciplina_nome %> (Nv <%= modificador.nivel_minimo %>)</p>
      <p>Custo: <%= modificador.operacao_custo %> <%= modificador.valor_custo %></p>
      <div>
        <%= link_to "Ver", modificador %>
        <%= link_to "Editar", edit_modificador_path(modificador) %>
        <%= link_to "Deletar", modificador, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  <% end %>
</div>