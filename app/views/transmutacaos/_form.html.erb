<%= form_with(model: transmutacao) do |form| %>
  <% if transmutacao.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(transmutacao.errors.count, "erro") %> encontrados:</h2>
      <ul>
        <% transmutacao.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :nome, "Nome:" %>
    <%= form.text_field :nome %>
  </div>

  <div>
    <%= form.label :descricao, "Descrição:" %>
    <%= form.text_area :descricao %>
  </div>

  <div>
    <%= form.label :dado_poder, "Dado de Poder:" %>
    <%= form.select :dado_poder, ["d4", "d6", "d8", "d10", "d12", "d20"] %>
  </div>

  <div>
    <%= form.label :custo_multiplicador, "Multiplicador de Custo:" %>
    <%= form.number_field :custo_multiplicador, step: 0.1 %>
  </div>

  <div>
    <%= form.label :basica, "Carta Básica?" %>
    <%= form.check_box :basica %>
  </div>

  <div>
    <%= form.label :disciplina, "Disciplina:" %>
    <%= form.select :disciplina, [
      ["Nenhuma (Básica)", ""],
      ["Superior (Vida/Cura)", "superior"],
      ["Esquerda Superior (Mente)", "esquerda_superior"],
      ["Direita Superior (Melhoria)", "direita_superior"],
      ["Esquerda Inferior (Contenção)", "esquerda_inferior"],
      ["Direita Inferior (Destruição)", "direita_inferior"]
    ], include_blank: false %>
  </div>

  <div>
    <%= form.label :nivel_minimo, "Nível Mínimo na Disciplina:" %>
    <%= form.number_field :nivel_minimo %>
  </div>

  <div>
    <%= form.submit "Salvar" %>
  </div>
<% end %>
