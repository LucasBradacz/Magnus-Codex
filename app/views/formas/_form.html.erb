<%= form_with(model: forma) do |form| %>
  <% if forma.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(forma.errors.count, "erro") %> encontrados:</h2>
      <ul>
        <% forma.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :nome, "Nome:" %>
    <%= form.text_field :nome %>
  </div>

  <div>
    <%= form.label :descricao, "Descrição:" %>
    <%= form.text_area :descricao %>
  </div>

  <div>
    <%= form.label :alcance, "Alcance:" %>
    <%= form.text_field :alcance %>
  </div>

  <div>
    <%= form.label :tamanho, "Tamanho:" %>
    <%= form.text_field :tamanho %>
  </div>

  <div>
    <%= form.label :duracao, "Duração:" %>
    <%= form.text_field :duracao %>
  </div>

  <div>
    <%= form.label :custo_base, "Custo:" %>
    <%= form.number_field :custo_base %>
  </div>

  <div>
    <%= form.label :poder_base, "Poder:" %>
    <%= form.number_field :poder_base %>
  </div>

  <div>
    <%= form.label :basica, "Carta Básica?" %>
    <%= form.check_box :basica %>
  </div>

  <div>
    <%= form.label :disciplina, "Disciplina:" %>
    <%= form.select :disciplina, [
      ["Nenhuma (Básica)", ""],
      ["Superior (Vida/Cura)", "superior"],
      ["Esquerda Superior (Mente)", "esquerda_superior"],
      ["Direita Superior (Melhoria)", "direita_superior"],
      ["Esquerda Inferior (Contenção)", "esquerda_inferior"],
      ["Direita Inferior (Destruição)", "direita_inferior"]
    ], include_blank: false %>
  </div>

  <div>
    <%= form.label :nivel_minimo, "Nível Mínimo na Disciplina:" %>
    <%= form.number_field :nivel_minimo %>
  </div>

  <div>
    <%= form.submit "Salvar" %>
  </div>
<% end %>
